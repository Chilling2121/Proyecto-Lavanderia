# Configuración del servidor de desarrollo de Django
SECRET_KEY=django-insecure-tu-secret-key-aqui
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Configuración de base de datos
# DB_ENGINE puede ser 'mysql' o 'sqlite' (por defecto usa sqlite si no se define)
DB_ENGINE=sqlite
DB_NAME=lavafacil_db
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306
